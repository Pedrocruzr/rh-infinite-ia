import type { DescricaoCargoSession } from "./flow";

function escapeHtml(value: string) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function normalizeSentence(value: string): string {
  let text = String(value ?? "").trim();

  text = text
    .replace(/\s+/g, " ")
    .replace(/\s+,/g, ",")
    .replace(/\s+\./g, ".")
    .replace(/\s+:/g, ":")
    .replace(/\s+;/g, ";")
    .trim();

  if (!text) return "";
  text = text.charAt(0).toUpperCase() + text.slice(1);

  if (!/[.!?]$/.test(text)) {
    text += ".";
  }

  return text;
}

function normalizeItem(value: string): string {
  return normalizeSentence(value).replace(/[.!?]$/, "");
}

function splitList(text?: string) {
  return String(text ?? "")
    .split(/\n|;|,/)
    .map((item) => item.replace(/^\d+[\).\-\s]*/, "").trim())
    .filter(Boolean)
    .map(normalizeItem);
}

function splitActivities(text?: string) {
  return String(text ?? "")
    .split(/\n|;|,/)
    .map((item) => item.replace(/^\d+[\).\-\s]*/, "").trim())
    .filter(Boolean)
    .map(normalizeSentence);
}

function unique(items: string[]) {
  return [...new Set(items)];
}

function detectCompetenciasComportamentais(
  activity: string,
  conhecimentos: string[],
  habilidades: string[],
  organizacionais: string[]
) {
  const lower = activity.toLowerCase();
  const baseText = [...conhecimentos, ...habilidades, ...organizacionais].join(" ").toLowerCase();
  const result: string[] = [];

  if (/atendimento|cliente|fornecedor|visitante|telefone|ligaç|ligac|email|e-mail|recado|comunica/.test(lower)) {
    result.push("Comunicação", "Clareza", "Escuta", "Cordialidade");
  }

  if (/agenda|organiza|arquivo|document|cadastro|controle|planilha|relat/.test(lower)) {
    result.push("Organização", "Atenção", "Disciplina", "Responsabilidade");
  }

  if (/prazo|acompanh|entrega|demanda|rotina|processo|suporte/.test(lower)) {
    result.push("Planejamento", "Foco em resultados", "Responsabilidade");
  }

  if (/análise|analise|confer|valida|chec/.test(lower)) {
    result.push("Análise crítica", "Atenção", "Critério");
  }

  if (/atendimento|comunicação|comunicacao|redação|redacao/.test(baseText)) {
    result.push("Comunicação", "Clareza");
  }

  if (/controle|processo|rotina|excel|planilha|office|sistema/.test(baseText)) {
    result.push("Organização", "Atenção", "Disciplina");
  }

  if (result.length === 0) {
    result.push("Organização", "Responsabilidade", "Planejamento");
  }

  return unique(result);
}

function countIncidence(
  atividades: string[],
  conhecimentos: string[],
  habilidades: string[],
  organizacionais: string[]
) {
  const map = new Map<string, number>();

  for (const atividade of atividades) {
    const competencias = detectCompetenciasComportamentais(
      atividade,
      conhecimentos,
      habilidades,
      organizacionais
    );

    for (const competencia of competencias) {
      map.set(competencia, (map.get(competencia) ?? 0) + 1);
    }
  }

  return [...map.entries()]
    .map(([competencia, incidencia]) => ({
      competencia,
      incidencia,
    }))
    .sort((a, b) => b.incidencia - a.incidencia || a.competencia.localeCompare(b.competencia));
}

function computeGrade(incidencia: number, totalAtividades: number) {
  const ratio = totalAtividades > 0 ? incidencia / totalAtividades : 0;

  if (ratio >= 0.8) return "Grau 5";
  if (ratio >= 0.6) return "Grau 4";
  if (ratio >= 0.4) return "Grau 3";
  if (ratio >= 0.2) return "Grau 2";
  return "Grau 1";
}

function renderList(items: string[]) {
  return items.map((item) => `<li>${escapeHtml(item)}</li>`).join("");
}

function buildMissao(cargo: string, atividades: string[]) {
  if (atividades.length === 0) {
    return `Executar com qualidade as responsabilidades do cargo de ${cargo}, contribuindo para a organização, continuidade e eficiência das rotinas da função.`;
  }

  const primeira = atividades[0].replace(/[.!?]$/, "").toLowerCase();
  return `Executar o cargo de ${cargo} com qualidade, organização e responsabilidade, garantindo ${primeira} e apoiando a continuidade das entregas e dos processos da função.`;
}

