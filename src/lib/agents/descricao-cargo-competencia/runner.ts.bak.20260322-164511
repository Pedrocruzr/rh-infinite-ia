      grau: "Grau esperado conforme execução prática",
    })),
    ...organizacionais.map((item) => ({
      tipo: "Organizacional",
      competencia: item,
      grau: "Grau esperado conforme cultura e padrão interno",
    })),
    ...incidencia.slice(0, 10).map((item) => ({
      tipo: "Comportamental",
      competencia: item.competencia,
      grau: item.grau,
    })),
