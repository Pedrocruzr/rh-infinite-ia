import type { MapeamentoSession } from "./flow";

function escapeHtml(value: string) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function normalizeText(value: string) {
  let text = String(value ?? "").trim();

  text = text
    .replace(/\s+/g, " ")
    .replace(/\s+,/g, ",")
    .replace(/\s+\./g, ".")
    .replace(/\s+:/g, ":")
    .replace(/\s+;/g, ";")
    .trim();

  if (!text) return "";
  return text.charAt(0).toUpperCase() + text.slice(1);
}

function splitItems(text?: string) {
  return String(text ?? "")
    .split(/\n|;|,/)
    .map((item) => normalizeText(item))
    .filter(Boolean);
}

function unique(items: string[]) {
  return [...new Set(items)];
}

function groupBySimilarity(items: string[]) {
  const groups: Record<string, string[]> = {};

  for (const item of items) {
    const lower = item.toLowerCase();

    let group = "Organização";

    if (
      /agilidade|atenção|atencao|responsabilidade|disciplina|foco|planejamento|execução|execucao|produtividade|eficiência|eficiencia/.test(lower)
    ) {
      group = "Eficiência";
    } else if (
      /comunicação|comunicacao|clareza|escuta|negociação|negociacao|relacionamento|interação|interacao/.test(lower)
    ) {
      group = "Comunicação";
    } else if (
      /análise|analise|crítica|critica|organização|organizacao|método|metodo|controle|padronização|padronizacao/.test(lower)
    ) {
      group = "Organização";
    }

    if (!groups[group]) groups[group] = [];
    groups[group].push(item);
  }

  for (const key of Object.keys(groups)) {
    groups[key] = unique(groups[key]);
  }

  return groups;
}

function countIncidence(groups: Record<string, string[]>, activities: string[]) {
  const result: Array<{ grupo: string; incidencia: number }> = [];

  for (const [grupo, competencias] of Object.entries(groups)) {
    let incidencia = 0;

    for (const atividade of activities) {
      const atividadeLower = atividade.toLowerCase();
      const found = competencias.some((competencia) => {
        const c = competencia.toLowerCase();
        return atividadeLower.includes(c.split(" ")[0]) || atividadeLower.includes(c);
      });

      if (found) incidencia += 1;
    }

    if (incidencia === 0 && competencias.length > 0) {
      incidencia = 1;
    }

    result.push({ grupo, incidencia });
  }

  return result;
}

function computeGrade(incidencia: number) {
  if (incidencia >= 5) return "Grau 5";
  if (incidencia === 4) return "Grau 4";
  if (incidencia === 3) return "Grau 3";
  if (incidencia === 2) return "Grau 2";
  return "Grau 1";
}

function renderList(items: string[]) {
  return items.map((item) => `<li>${escapeHtml(item)}</li>`).join("");
}

function renderActivitiesWithCompetencias(activities: string[], competencias: string[]) {
  return activities
    .map((atividade, index) => {
      const selected = competencias.slice(index, index + 3).length
        ? competencias.slice(index, index + 3)
        : competencias.slice(0, 3);

      return `
        <div style="margin:0 0 22px 0;">
          <p style="margin:0 0 8px 0;"><strong>Atividade ${index + 1}:</strong> ${escapeHtml(atividade)}</p>
          <ul style="margin:0 0 0 22px; padding:0;">
            ${renderList(selected)}
          </ul>
        </div>
      `;
    })
    .join("");
}

export function buildMapeamentoCompetenciasReport(
  session: MapeamentoSession
): string {
  const cargo = normalizeText(session.cargo ?? "Não informado");
  const atividades = splitItems(session.atividades);
  const competencias = splitItems(session.competencias);

  const grupos = groupBySimilarity(competencias);
  const incidencias = countIncidence(grupos, atividades)
    .map((item) => ({
      ...item,
      grau: computeGrade(item.incidencia),
    }))
    .sort((a, b) => b.incidencia - a.incidencia);

  const gruposConsolidados = Object.keys(grupos);

  const resumoExecutivo =
    gruposConsolidados.length > 0
      ? `O cargo de ${cargo} apresenta predominância do grupo ${gruposConsolidados[0]}, indicando maior necessidade de comportamentos ligados a esse eixo no desempenho da função. Os demais grupos aparecem como complementares e contribuem para a sustentação da rotina, da qualidade e da comunicação no cargo.`
      : `O cargo de ${cargo} apresenta um conjunto de competências que precisa ser interpretado em conjunto com as atividades do cargo para definição da prioridade comportamental.`;

  return `
<section>
  <h1 style="font-size:30px; font-weight:800; margin:0 0 24px 0;">RELATÓRIO DE MAPEAMENTO DE COMPETÊNCIAS COMPORTAMENTAIS</h1>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">1. Cargo analisado</h2>
  <p style="margin:0 0 24px 0;">${escapeHtml(cargo)}</p>

  <hr style="margin:0 0 24px 0; border:none; border-top:1px solid #ddd;" />

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">2. Atividades do cargo</h2>
  <ol style="margin:0 0 24px 22px; padding:0;">
    ${atividades.map((item) => `<li>${escapeHtml(item)}</li>`).join("")}
  </ol>

  <hr style="margin:0 0 24px 0; border:none; border-top:1px solid #ddd;" />

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">3. Competências comportamentais por atividade</h2>
  <p style="margin:0 0 16px 0;">Nesta etapa, o relatório distribui as competências comportamentais associadas a cada atividade do cargo, mostrando quais comportamentos sustentam a execução prática de cada entrega.</p>
  ${renderActivitiesWithCompetencias(atividades, competencias)}

  <hr style="margin:0 0 24px 0; border:none; border-top:1px solid #ddd;" />

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">4. Grupos de similaridade consolidados</h2>
  <p style="margin:0 0 16px 0;">Aqui as competências semelhantes são agrupadas em blocos maiores, para facilitar a leitura estratégica e evitar análise fragmentada de competências muito próximas entre si.</p>
  <ul style="margin:0 0 24px 22px; padding:0;">
    ${renderList(gruposConsolidados)}
  </ul>

  <hr style="margin:0 0 24px 0; border:none; border-top:1px solid #ddd;" />

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">5. Distribuição das competências por grupo</h2>
  <p style="margin:0 0 16px 0;">Esta seção mostra quais competências específicas ficaram dentro de cada grupo consolidado, ajudando a entender a composição comportamental de cada eixo mapeado.</p>
  ${Object.entries(grupos)
    .map(
      ([grupo, itens]) => `
        <div style="margin:0 0 22px 0;">
          <p style="margin:0 0 8px 0;"><strong>Grupo: ${escapeHtml(grupo)}</strong></p>
          <ul style="margin:0 0 0 22px; padding:0;">
            ${renderList(itens)}
          </ul>
        </div>
      `
    )
    .join("")}

  <hr style="margin:0 0 24px 0; border:none; border-top:1px solid #ddd;" />

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">6. Incidência dos grupos nas atividades</h2>
  <p style="margin:0 0 16px 0;">Incidência representa em quantas atividades do cargo aquele grupo aparece de forma relevante. Quanto maior a incidência, maior a presença prática daquele grupo na rotina da função.</p>
  <table style="width:100%; border-collapse:collapse; margin:0 0 24px 0;">
    <thead>
      <tr>
        <th style="text-align:left; border:1px solid #ddd; padding:8px;">Grupo</th>
        <th style="text-align:left; border:1px solid #ddd; padding:8px;">Nº de atividades em que aparece</th>
      </tr>
    </thead>
    <tbody>
      ${incidencias
        .map(
          (item) => `
            <tr>
              <td style="border:1px solid #ddd; padding:8px;">${escapeHtml(item.grupo)}</td>
              <td style="border:1px solid #ddd; padding:8px;">${item.incidencia}</td>
            </tr>
          `
        )
        .join("")}
    </tbody>
  </table>

  <hr style="margin:0 0 24px 0; border:none; border-top:1px solid #ddd;" />

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">7. Grau de relevância por grupo</h2>
  <p style="margin:0 0 16px 0;">O grau é a tradução da incidência em uma escala de prioridade. Ele resume o peso relativo de cada grupo no mapeamento e ajuda a hierarquizar o que é mais crítico para o cargo.</p>
  <table style="width:100%; border-collapse:collapse; margin:0 0 24px 0;">
    <thead>
      <tr>
        <th style="text-align:left; border:1px solid #ddd; padding:8px;">Grupo</th>
        <th style="text-align:left; border:1px solid #ddd; padding:8px;">Incidência</th>
        <th style="text-align:left; border:1px solid #ddd; padding:8px;">Grau</th>
      </tr>
    </thead>
    <tbody>
      ${incidencias
        .map(
          (item) => `
            <tr>
              <td style="border:1px solid #ddd; padding:8px;">${escapeHtml(item.grupo)}</td>
              <td style="border:1px solid #ddd; padding:8px;">${item.incidencia}</td>
              <td style="border:1px solid #ddd; padding:8px;">${escapeHtml(item.grau)}</td>
            </tr>
          `
        )
        .join("")}
    </tbody>
  </table>

  <hr style="margin:0 0 24px 0; border:none; border-top:1px solid #ddd;" />

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">8. Classificação final (ordem de relevância)</h2>
  <p style="margin:0 0 16px 0;">Nesta etapa final, os grupos são organizados do mais relevante para o menos relevante, considerando incidência e grau. Essa ordem ajuda a orientar seleção, desenvolvimento e priorização do perfil ideal.</p>
  <ol style="margin:0 0 24px 22px; padding:0;">
    ${incidencias
      .map(
        (item) => `
          <li><strong>${escapeHtml(item.grupo)}</strong> — ${escapeHtml(item.grau)}</li>
        `
      )
      .join("")}
  </ol>

  <hr style="margin:0 0 24px 0; border:none; border-top:1px solid #ddd;" />

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">9. Resumo executivo do perfil comportamental</h2>
  <p style="margin:0 0 16px 0;">
    ${escapeHtml(resumoExecutivo)}
  </p>
  <p style="margin:0;">
    De forma geral, o perfil esperado para esse cargo tende a reunir características coerentes com os grupos mais incidentes e mais relevantes do mapeamento, servindo como referência prática para seleção, avaliação e desenvolvimento.
  </p>
</section>
  `.trim();
}
