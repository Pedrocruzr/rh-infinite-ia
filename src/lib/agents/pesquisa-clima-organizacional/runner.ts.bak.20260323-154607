  const questionBlocks = titles
    .map((title) => {
      const all = FULL_QUESTIONS[title];
      const items = mode === "short" ? all.slice(0, 2) : all;
      return renderQuestionBlock(title, items);
    })
    .join("");

  const intro =
    mode === "simple"
      ? "Abaixo está uma versão mais simples e direta do questionário, mantendo os pontos centrais do clima organizacional."
      : mode === "professional"
      ? "Abaixo está uma versão mais profissional do questionário, com estrutura organizada, linguagem formal e aplicação executiva."
      : mode === "dimensions"
      ? "Abaixo está uma versão organizada por dimensões de clima, facilitando aplicação, leitura e consolidação por bloco."
      : mode === "short"
      ? "Abaixo está uma versão mais curta do questionário, reduzida para aplicação mais ágil sem perder os principais fatores de clima."
      : "Abaixo está o modelo-base completo de questionário de clima organizacional.";

  return `
    <p style="margin:0 0 8px 0;"><strong>Objetivo:</strong> entender a percepção dos colaboradores sobre o ambiente de trabalho e identificar pontos fortes e oportunidades de melhoria.</p>
    <p style="margin:0 0 16px 0;">${escapeHtml(intro)}</p>

