function buildImprovedQuestionnaireReport(session: ClimaSession) {
  const demandaInicial = normalizeSentence(session.nomeEmpresa ?? "Não informado");
  const objetivoComplementar = normalizeSentence(session.objetivoPesquisa ?? "Não informado");
  const publico = normalizeLine(session.publicoAlvo ?? "Não informado");
  const respondentes = normalizeLine(session.quantidadeRespondentes ?? "Não informado");
  const questionarioUsuario = String(session.questionarioUsuario ?? "").trim();
  const dimensoes = unique(splitList(session.dimensoesPrioritarias));

  const dimensoesFinais = dimensoes.length
    ? dimensoes
    : [
        "Liderança",
        "Comunicação",
        "Reconhecimento e valorização",
        "Trabalho em equipe",
        "Condições de trabalho",
        "Desenvolvimento e crescimento",
        "Organização e processos",
        "Engajamento e pertencimento",
      ];

  return `
<section>
  <h1 style="font-size:30px; font-weight:800; margin:0 0 24px 0;">MODELO APRIMORADO DE PESQUISA DE CLIMA ORGANIZACIONAL</h1>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">1. Contexto da solicitação</h2>
  <p style="margin:0 0 8px 0;"><strong>Demanda inicial:</strong> ${escapeHtml(demandaInicial)}</p>
  <p style="margin:0 0 8px 0;"><strong>Objetivo complementar:</strong> ${escapeHtml(objetivoComplementar)}</p>
  <p style="margin:0 0 8px 0;"><strong>Público-alvo:</strong> ${escapeHtml(publico)}</p>
  <p style="margin:0 0 24px 0;"><strong>Quantidade estimada de respondentes:</strong> ${escapeHtml(respondentes)}</p>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">2. Modelo enviado pelo usuário</h2>
  <div style="margin:0 0 24px 0; padding:16px; border:1px solid #e5e7eb; border-radius:12px; white-space:pre-wrap;">${escapeHtml(questionarioUsuario)}</div>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">3. Comparativo com a base de conhecimento</h2>
  <ul style="margin:0 0 24px 22px; padding:0;">
    <li>Foi comparado o modelo enviado com a estrutura-base de pesquisa de clima organizacional disponível no agente.</li>
    <li>A base recomenda questionário com escala Likert, dimensões clássicas de clima, perguntas abertas, perguntas de perfil e orientações de aplicação.</li>
    <li>Também foram considerados fatores de liderança, comunicação, reconhecimento, desenvolvimento, relacionamento, ambiente, autonomia, identidade e padrões.</li>
    <li>As dimensões priorizadas nesta demanda foram: ${escapeHtml(dimensoesFinais.join(", "))}.</li>
    <li>O modelo abaixo já foi reorganizado e ampliado para ficar mais completo, comparável e pronto para uso interno.</li>
  </ul>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">4. Novo modelo com melhorias</h2>
  ${standardQuestionnaireHtml()}

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">5. Recomendações finais</h2>
  <ul style="margin:0 0 0 22px; padding:0;">
    <li>Usar linguagem simples e uniforme em todas as afirmações.</li>
    <li>Preservar anonimato e evitar identificação de respondentes em grupos pequenos.</li>
    <li>Aplicar a pesquisa com comunicação prévia sobre objetivo, confidencialidade e uso dos resultados.</li>
    <li>Depois da coleta, consolidar resultados por dimensão e construir plano de ação.</li>
  </ul>
</section>
`;
}

export function buildClimaReport(session: ClimaSession) {
  if (String(session.questionarioUsuario ?? "").trim()) {
    return buildImprovedQuestionnaireReport(session);
  }

  const demandaInicial = normalizeSentence(session.nomeEmpresa ?? "Não informado");
  const objetivoComplementar = normalizeSentence(session.objetivoPesquisa ?? "Não informado");
  const publico = normalizeLine(session.publicoAlvo ?? "Não informado");
  const respondentes = normalizeLine(session.quantidadeRespondentes ?? "Não informado");
  const usarPadrao = /sim/i.test(String(session.usarQuestionarioPadrao ?? ""));
  const dimensoes = unique(splitList(session.dimensoesPrioritarias));
  const observacoes =
    ["não", "nao", ""].includes(String(session.observacoes ?? "").trim().toLowerCase())
      ? ""
      : normalizeSentence(session.observacoes ?? "");

  const dimensoesFinais = dimensoes.length
    ? dimensoes
    : [
        "Liderança",
        "Comunicação",
        "Reconhecimento",
        "Desenvolvimento",
        "Relacionamento",
        "Ambiente",
        "Autonomia",
        "Identidade",
        "Padrões",
      ];

  return `
<section>
  <h1 style="font-size:30px; font-weight:800; margin:0 0 24px 0;">PESQUISA DE CLIMA ORGANIZACIONAL</h1>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">1. Contexto da pesquisa</h2>
  <p style="margin:0 0 8px 0;"><strong>Demanda inicial:</strong> ${escapeHtml(demandaInicial)}</p>
  <p style="margin:0 0 8px 0;"><strong>Objetivo complementar:</strong> ${escapeHtml(objetivoComplementar)}</p>
  <p style="margin:0 0 8px 0;"><strong>Público-alvo:</strong> ${escapeHtml(publico)}</p>
  <p style="margin:0 0 24px 0;"><strong>Quantidade estimada de respondentes:</strong> ${escapeHtml(respondentes)}</p>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">2. Estrutura recomendada da pesquisa</h2>
  <p style="margin:0 0 8px 0;">${usarPadrao
    ? "A recomendação é utilizar o questionário padrão de clima organizacional com estrutura completa."
    : "A recomendação é estruturar a pesquisa com base no modelo padrão, adaptando a linguagem ao contexto da organização."}</p>
  <p style="margin:0 0 24px 0;">A base de conhecimento sugere estrutura com escala de resposta, dimensões de clima, perguntas abertas, perguntas de perfil e critérios claros de interpretação.</p>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">3. Modelo base pronto para uso</h2>
  ${standardQuestionnaireHtml()}

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">4. Dimensões prioritárias para análise</h2>
  <ul style="margin:0 0 24px 22px; padding:0;">
    ${renderList(dimensoesFinais)}
  </ul>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">5. Base teórica de interpretação</h2>
  <p style="margin:0 0 8px 0;">A leitura do clima pode considerar fatores clássicos como estrutura, responsabilidade, desafio, recompensa, relacionamento, cooperação, conflito, identidade e padrões.</p>
  <p style="margin:0 0 8px 0;">Também é recomendável conectar a análise com teorias de motivação e percepção para interpretar por que colaboradores respondem de formas diferentes ao mesmo contexto organizacional.</p>
  ${observacoes ? `<p style="margin:0 0 24px 0;"><strong>Observações adicionais:</strong> ${escapeHtml(observacoes)}</p>` : `<p style="margin:0 0 24px 0;"></p>`}

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">6. Recomendações executivas</h2>
  <ul style="margin:0 0 0 22px; padding:0;">
    <li>Aplicar a pesquisa com comunicação clara sobre objetivo, confidencialidade e uso dos resultados.</li>
    <li>Consolidar médias por dimensão e identificar prioridades de melhoria.</li>
    <li>Cruzar dados quantitativos com respostas abertas para aprofundar causas.</li>
    <li>Produzir plano de ação com responsáveis, prazos e acompanhamento em até 90 dias.</li>
  </ul>
</section>
`;
}
