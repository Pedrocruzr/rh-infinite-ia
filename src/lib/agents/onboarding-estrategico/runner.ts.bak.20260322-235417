function escapeHtml(value: string) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function normalizeSentence(value: string) {
  let text = String(value ?? "").trim().replace(/\s+/g, " ");
  if (!text) return "";
  text = text.charAt(0).toUpperCase() + text.slice(1);
  if (!/[.!?]$/.test(text)) text += ".";
  return text;
}

function normalizeLine(value: string) {
  return normalizeSentence(value).replace(/[.!?]$/, "");
}

function splitList(text?: string) {
  return String(text ?? "")
    .split(/\n|;|,/)
    .map((item) => item.replace(/^\d+[\).\-\s]*/, "").trim())
    .filter(Boolean)
    .map(normalizeLine);
}

function unique(items: string[]) {
  return [...new Set(items)];
}

function parseHours(text?: string) {
  const raw = String(text ?? "").toLowerCase();
  const m = raw.match(/\d+/);
  if (!m) return 5;
  return Number(m[0]);
}

function renderList(items: string[]) {
  return items.map((item) => `<li>${escapeHtml(item)}</li>`).join("");
}

function pickDepartmentThemes(allThemes: string[], matcher: RegExp, fallback: string[]) {
  const selected = allThemes.filter((item) => matcher.test(item.toLowerCase()));
  return selected.length ? selected : fallback;
}

function buildDepartmentModules(departments: string[], themes: string[]) {
  const modules: string[] = [];

  const hasComercial = departments.some((dep) => /comercial|vendas/.test(dep.toLowerCase()));
  const hasAdministrativo = departments.some((dep) => /administr|adm/.test(dep.toLowerCase()));

  if (hasComercial) {
    const comercialThemes = pickDepartmentThemes(
      themes,
      /atendimento|telef|cliente|meta|crm|comunica/,
      [
        "Atendimento telefônico",
        "Atendimento ao público",
        "Metas mensais",
        "Uso do CRM no fluxo comercial",
        "Padrão de comunicação com cliente",
      ]
    );

    modules.push(`
      <h3 style="font-size:20px; font-weight:700; margin:0 0 10px 0;">Módulo Comercial / Vendas</h3>
      <p style="margin:0 0 10px 0;">Baseei este bloco no departamento Comercial da base, que destaca produtos e serviços, técnicas de vendas, metas e indicadores, atendimento ao cliente e relaciona CRM Corporativo.</p>
      <p style="margin:0 0 8px 0;"><strong>Temas do módulo:</strong></p>
      <ul style="margin:0 0 16px 22px; padding:0;">
        ${renderList(comercialThemes)}
      </ul>
      <p style="margin:0 0 8px 0;"><strong>Vídeo recomendado da base:</strong></p>
      <p style="margin:0 0 24px 0;">Atendimento ao Cliente: Nosso Diferencial — cobre empatia, resolução de problemas e comunicação eficaz; indicado para Operacional e Técnico.</p>
    `);
  }

  if (hasAdministrativo) {
    const administrativoThemes = pickDepartmentThemes(
      themes,
      /e-mail|email|relat|organiz|demanda|registro|controle|cont[aá]bil|contabil|obriga/,
      [
        "Checagem de e-mail",
        "Confecção de relatórios administrativos",
        "Rotina de organização de demandas",
        "Boas práticas de registro e controle",
        "Interface com processos contábeis e obrigações internas",
      ]
    );

    modules.push(`
      <h3 style="font-size:20px; font-weight:700; margin:0 0 10px 0;">Módulo Administrativo</h3>
      <p style="margin:0 0 10px 0;">A base não traz um departamento “Administrativo”, então este bloco foi estruturado com seus temas e com proximidade ao departamento Financeiro, que na base cobre processos contábeis, controles internos, orçamento e compliance.</p>
      <p style="margin:0 0 8px 0;"><strong>Temas do módulo:</strong></p>
      <ul style="margin:0 0 24px 22px; padding:0;">
        ${renderList(administrativoThemes)}
      </ul>
    `);
  }

  if (!modules.length) {
    modules.push(`
      <p style="margin:0 0 24px 0;">Os módulos departamentais foram estruturados com base nos departamentos informados e nos temas priorizados pelo usuário, mantendo coerência com os elementos disponíveis na base.</p>
    `);
  }

  return modules.join("");
}

function buildSystemsSection(selectedSystems: string[]) {
  const official = selectedSystems.filter((item) => SYSTEMS_BASE[item]);
  const nonBase = selectedSystems.filter((item) => !SYSTEMS_BASE[item]);

  const officialHtml = official
    .map((item) => {
      const sys = SYSTEMS_BASE[item];
      return `
        <div style="margin:0 0 18px 0;">
          <p style="margin:0 0 8px 0;"><strong>${escapeHtml(sys.nome)}</strong></p>
          <p style="margin:0 0 4px 0;"><strong>Descrição:</strong> ${escapeHtml(sys.descricao)}</p>
          <p style="margin:0 0 4px 0;"><strong>Responsável:</strong> ${escapeHtml(sys.responsavel)}</p>
          <p style="margin:0 0 4px 0;"><strong>Acesso:</strong> ${escapeHtml(sys.acesso)}</p>
          <p style="margin:0 0 0 0;"><strong>Tempo de apresentação na base:</strong> ${escapeHtml(sys.tempo)}</p>
        </div>
      `;
    })
    .join("");

  const noteHtml = nonBase.length
    ? nonBase
        .map((item) => {
          if (/e-mail|email corporativo/i.test(item)) {
            return `<p style="margin:0 0 8px 0;"><strong>Observação importante</strong><br />E-mail corporativo foi solicitado por você, mas não aparece na lista de sistemas da base. Por isso, recomendo tratar esse tema como orientação operacional do departamento, sem classificá-lo como sistema oficial da base.</p>`;
          }
          return `<p style="margin:0 0 8px 0;"><strong>Observação importante</strong><br />${escapeHtml(item)} foi solicitado por você, mas não aparece na lista de sistemas da base. Por isso, recomendo tratar esse tema como orientação operacional, e não como sistema oficial da base.</p>`;
        })
        .join("")
    : "";

  return officialHtml + noteHtml;
}

function buildMaterialsSection(selectedDocs: string[]) {
  return selectedDocs
    .map((doc) => {
      const info = MATERIALS_BASE[doc];
      if (info) {
        return `<li><strong>${escapeHtml(info.titulo)}</strong> — ${escapeHtml(info.descricao)}</li>`;
      }
      return `<li><strong>${escapeHtml(doc)}</strong> — Material informado pelo usuário para apoio à integração.</li>`;
    })
    .join("");
}

