export function buildOnboardingReport(session: OnboardingSession) {
  const quantidade = normalizeLine(session.quantidadeColaboradores ?? "Não informado");
  const nivel = normalizeLine(session.nivelHierarquico ?? "Não informado");
  const departments = unique(splitList(session.departamentos));
  const themes = unique(splitList(session.temasDepartamentos));
  const facilitadores = normalizeLine(session.facilitadoresDisponiveis ?? "Não informado");
  const tempo = normalizeLine(session.tempoIntegracao ?? "Não informado");
  const totalHours = parseHours(session.tempoIntegracao);
  const selectedSystems = unique(splitList(session.sistemasApresentados));
  const selectedDocs = unique(splitList(session.documentosBase));
  const dinamicas = unique(splitList(session.dinamicaPropria));
  const selectedDynamic = dinamicas[0] ?? "Dinâmica não informada";

  const hasComercial = departments.some((dep) => /comercial|vendas/.test(dep.toLowerCase()));
  const hasAdministrativo = departments.some((dep) => /administr|adm/.test(dep.toLowerCase()));

  return `
<section>
  <h1 style="font-size:30px; font-weight:800; margin:0 0 24px 0;">ROTEIRO DE INTEGRAÇÃO PERSONALIZADO PRONTO</h1>

  <p style="margin:0 0 8px 0;"><strong>Quantidade de colaboradores:</strong> ${escapeHtml(quantidade)}</p>
  <p style="margin:0 0 8px 0;"><strong>Nível hierárquico:</strong> ${escapeHtml(nivel)}</p>
  <p style="margin:0 0 8px 0;"><strong>Departamentos:</strong> ${escapeHtml(departments.join(", "))}</p>
  <p style="margin:0 0 8px 0;"><strong>Facilitadores disponíveis:</strong> ${escapeHtml(facilitadores)}</p>
  <p style="margin:0 0 24px 0;"><strong>Tempo total da integração:</strong> ${escapeHtml(tempo)}</p>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">1. Alinhamento Cultural</h2>
  <p style="margin:0 0 8px 0;"><strong>Missão:</strong> ${escapeHtml(normalizeLine(session.missaoEmpresa ?? "Não informado"))}</p>
  <p style="margin:0 0 8px 0;"><strong>Visão:</strong> ${escapeHtml(normalizeLine(session.visaoEmpresa ?? "Não informado"))}</p>
  <p style="margin:0 0 16px 0;"><strong>Valores:</strong> ${escapeHtml(normalizeLine(session.valoresEmpresa ?? "Não informado"))}</p>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">2. Dinâmica Selecionada</h2>
  <ul style="margin:0 0 24px 22px; padding:0;">
    ${renderList(dinamicas)}
  </ul>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">3. Módulos Departamentais</h2>
  ${buildDepartmentModules(departments, themes)}

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">4. Apresentação de Sistemas</h2>
  ${buildSystemsSection(selectedSystems)}

  <h2 style="font-size:22px; font-weight:700; margin:24px 0 10px 0;">5. Documentação de Apoio</h2>
  <p style="margin:0 0 8px 0;"><strong>Materiais escolhidos por você e presentes na base:</strong></p>
  <ul style="margin:0 0 24px 22px; padding:0;">
    ${buildMaterialsSection(selectedDocs)}
  </ul>

  <h2 style="font-size:22px; font-weight:700; margin:0 0 10px 0;">6. Cronograma Integrado</h2>
  ${buildCronograma(totalHours, selectedDynamic, hasComercial, hasAdministrativo, selectedSystems)}

  <h2 style="font-size:22px; font-weight:700; margin:24px 0 10px 0;">Resumo de compatibilidade da base</h2>
  <p style="margin:0 0 8px 0;">Dinâmica escolhida: ${escapeHtml(selectedDynamic)}.</p>
  <p style="margin:0 0 8px 0;">Vídeos usados: compatíveis com integração geral e, quando aplicável, com o módulo comercial.</p>
  <p style="margin:0 0 8px 0;">Materiais usados: os documentos listados foram tratados a partir dos materiais escolhidos e dos itens da base.</p>
  <p style="margin:0 0 8px 0;">Sistema oficial usado: ${escapeHtml(selectedSystems.filter((item) => SYSTEMS_BASE[item]).join(", ") || "Nenhum sistema oficial da base informado")}.</p>
  <p style="margin:0 0 0 0;">Itens que não constam como sistema oficial da base foram mantidos apenas como prática operacional ou orientação de rotina.</p>
</section>
`;
}
