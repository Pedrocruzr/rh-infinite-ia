export type OnboardingField =
  | "quantidadeColaboradores"
  | "nivelHierarquico"
  | "departamentos"
  | "missaoEmpresa"
  | "visaoEmpresa"
  | "valoresEmpresa"
  | "temasDepartamentos"
  | "facilitadoresDisponiveis"
  | "sistemasApresentados"
  | "tempoIntegracao"
  | "temDinamicaPropria"
  | "categoriaDinamica"
  | "dinamicaPropria"
  | "validacaoDinamicaSugerida"
  | "documentosBase";

