      <tr><td>Produtividade (${esc(unidade)})</td><td>${esc(round2(produtividade))}</td><td>${esc(round2(metaProdutividade))}</td><td>${esc(round2(atingProd))}%</td><td>${esc(classeMeta)}</td></tr>
    </tbody>
  </table>

  <h2>3. Cálculo de Produtividade Detalhado</h2>
